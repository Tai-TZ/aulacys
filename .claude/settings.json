{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 scripts/log_ai_event.py --tool=claude",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 scripts/log_ai_event.py --tool=claude",
            "timeout": 10
          }
        ]
      }
    ]
    
  }
}


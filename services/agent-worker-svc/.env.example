# agent-worker-svc — one image, four processes (docs/CONFIG.md)
# Copy to .env and set AGENT_NAME per process (or override in shell).

AGENT_NAME=credit
# AGENT_NAME=operations
# AGENT_NAME=compliance
# AGENT_NAME=critic

# Tool / policy addresses (workers call these when set)
CIC_SVC_URL=http://127.0.0.1:8300
INCOME_SVC_URL=http://127.0.0.1:8340
PROPERTY_SVC_URL=http://127.0.0.1:8330
AML_SVC_URL=http://127.0.0.1:8320
POLICY_SVC_URL=http://127.0.0.1:8100

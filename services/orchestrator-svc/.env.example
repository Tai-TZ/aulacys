# orchestrator-svc (:8000 or Cloud Run) — owns workflow/run state.
# Copy to .env. NEVER commit real passwords.
# Schema: search_path=orchestrator

# Local Docker Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?options=-csearch_path%3Dorchestrator"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres?options=-csearch_path%3Dorchestrator"

# GCP Cloud SQL example. Store the real values in Secret Manager, not in git.
# DATABASE_URL="postgresql://orchestrator_app:[PASSWORD]@[PRIVATE_IP]:5432/shb_orchestrator?options=-csearch_path%3Dorchestrator"
# DIRECT_URL="postgresql://orchestrator_migrator:[PASSWORD]@[PRIVATE_IP]:5432/shb_orchestrator?options=-csearch_path%3Dorchestrator"

DB_SCHEMA=orchestrator

{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "log-prompt",
            "command": "py -3 scripts/log_ai_event.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "log-stop",
            "command": "py -3 scripts/log_ai_event.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

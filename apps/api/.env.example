# ============================================
# Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ---- LLM Configuration ----
OPENAI_API_KEY=sk-your-key-here
# Or use other providers:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ---- Database (Supabase Postgres) ----
# Leave BOTH blank to run without a DB (in-memory fallback).
# Supabase -> Project Settings -> Database -> Connection string -> "Connect".
# Replace [YOUR-PASSWORD] and [PROJECT-REF]. NEVER commit the filled-in values.
#
# Runtime queries: transaction pooler, port 6543 (pgbouncer, IPv4-safe):
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations only: session pooler, port 5432 (Alembic uses this):
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
# Or Pinecone:
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ---- App Config ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Frontend (if separate) ----
# NEXT_PUBLIC_API_URL=http://localhost:8000
